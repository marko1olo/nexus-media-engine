@echo off
:: Включаем поддержку кодировки UTF-8 для красивого текста
chcp 65001 >nul
title Immersion Nexus Launcher
color 0C

echo ===================================================
echo             IMMERSION NEXUS 2.0
echo ===================================================
echo.

:: Переходим в папку, где лежит сам батник
cd /d "%~dp0"

:: Проверяем, установлен ли Python
python --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [ОШИБКА] Python не найден! 
    echo Убедись, что Python установлен, и при установке стояла галочка "Add Python to PATH".
    echo Скачать: https://www.python.org/downloads/
    echo.
    pause
    exit /b
)

:: Тихая проверка и установка Flask (если его нет)
echo [*] Проверка компонентов...
pip install flask opencv-python -q

echo [*] Запуск локального сервера...
echo [*] Браузер откроется автоматически через пару секунд.
echo.
echo ===================================================
echo   ДЛЯ ВЫХОДА ПРОСТО ЗАКРОЙ ЭТО ЧЕРНОЕ ОКНО
echo ===================================================
echo.

:: Запускаем невидимый таймер на 2 секунды, который сам откроет браузер
start cmd /c "timeout /t 2 >nul & start http://127.0.0.1:5000"

:: Запускаем сам сервер (окно консоли будет держать этот процесс)
python app.py

pause